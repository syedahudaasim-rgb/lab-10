#include <stdio.h>
#include <string.h>

int main() {
    char words[6][20];
    int seen[6] = {0};
    int i, j, k;

    for (i = 0; i < 6; i++) {
        scanf("%s", words[i]);
    }

    for (i = 0; i < 6; i++) {
        if (seen[i])
            continue;

        int count = 1;

        for (j = i + 1; j < 6; j++) {
            if (strcmp(words[i], words[j]) == 0) {
                count++;
                seen[j] = 1;
            }
        }

        printf("Word: ");
        for (k = 0; words[i][k] != '\0'; k++) {
            printf("%c ", words[i][k]);
        }
        printf("\nCount: %d\n", count);
    }

    return 0;
}
