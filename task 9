#include <stdio.h>

int main() {
    FILE *fptr;

    fptr = fopen("config.txt", "r");

    if (fptr == NULL) {
        printf("Config file not found. Creating default configuration...\n");

        fptr = fopen("config.txt", "w");

        if (fptr == NULL) {
            printf("Error: Unable to create file.\n");
            return 1;
        }

        fprintf(fptr, "max_users=50\n");
        fprintf(fptr, "timeout=30\n");
        fprintf(fptr, "mode=default\n");

        fclose(fptr);

        printf("Default config.txt created successfully.\n");
    } else {
        printf("Config file found.\n");
        fclose(fptr);
    }

    return 0;
}
